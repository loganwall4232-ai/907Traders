rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    // Existing collections — authenticated users
    match /trades/{id}       { allow read, write: if isAuthed(); }
    match /users/{id}        { allow read, write: if isAuthed(); }
    match /messages/{id}     { allow read, write: if isAuthed(); }
    match /topics/{id}       { allow read, write: if isAuthed(); }
    match /propAccounts/{id} { allow read, write: if isAuthed(); }
    match /settings/{id}     { allow read, write: if isAuthed(); }

    // News collections — read by all authed users, write by Cloud Functions only
    match /alerts/{id}    { allow read: if isAuthed(); allow write: if false; }
    match /newsItems/{id} { allow read: if isAuthed(); allow write: if false; }
  }
}
